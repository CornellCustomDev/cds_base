{% set heading_attributes = create_attribute() %}
{% set heading_level = level|default(2) %}
{% set has_url = url is not empty and url != 'No URL' ? 'yes' : 'no' %}

{% set heading_variants =
  html_cva(
    variants: {
    appearance: {
      'h1': 'h1',
      'h2': 'h2',
      'h3': 'h3',
      'h4': 'h4',
      'h5': 'h5',
      'h6': 'h6',
    },
  }
  )
%}
{% set heading_classes =
  heading_variants.apply({
    appearance: appearance,
  })
%}


{% set heading_content %}
  {% if has_url == 'yes' %}
    <a href="{{ url }}">{{ heading_text }}</a>
  {% else %}
    {{ heading_text }}
  {% endif %}
{% endset %}

{% if heading_level == 1 %}
  <h1 id="content" tabindex="-1"{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h1>
{% elseif heading_level == 2 %}
  <h2{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h2>
{% elseif heading_level == 3 %}
  <h3{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h3>
{% elseif heading_level == 4 %}
  <h4{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h4>
{% elseif heading_level == 5 %}
  <h5{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h5>
{% elseif heading_level == 6 %}
  <h6{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h6>
{% else %}
  <h2{{ heading_attributes.addClass(heading_classes) }}>{{ heading_content }}</h2>
{% endif %}
